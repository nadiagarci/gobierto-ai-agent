
<% 
  # Pre-procesamos la lógica del veredicto para evitar errores de sintaxis en el HTML
  viabilidad = @tender.analysis_data&.[]('viabilidad')
  badge_css = case viabilidad
              when 'Go' then 'bg-green-100 text-green-800 border-green-200'
              when 'No-Go' then 'bg-red-100 text-red-800 border-red-200'
              else 'bg-yellow-100 text-yellow-800 border-yellow-200'
              end
%>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  
  <%# 1. CABECERA %>
  <div class="md:flex md:items-center md:justify-between border-b border-gray-200 pb-6 mb-8">
    <div class="flex-1 min-w-0">
      <h2 class="text-3xl font-bold text-gray-900 sm:text-4xl sm:truncate">
        <%= @tender.title %>
      </h2>
    </div>
  </div>

  <%# 2. CUERPO PRINCIPAL (GRID) %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
    
    <%# COLUMNA IZQUIERDA: DOCUMENTACIÓN Y ESTADO %>
    <div class="lg:col-span-1 space-y-6">
      <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100 shadow-sm">
        <h4 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Panel de Control</h4>
        
        <div class="space-y-6">
          <%# Estado %>
          <div>
            <span class="block text-xs text-gray-500 font-medium">Estado del Proyecto</span>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-green-100 text-green-800 mt-1 border border-green-200">Activo</span>
          </div>

          <%# Descarga de PDF (Corregido) %>
          <div>
            <span class="block text-xs text-gray-500 font-medium mb-2 uppercase tracking-tight">Documento Original</span>
            <div class="flex items-center justify-between p-3 bg-white rounded-xl border border-gray-200 shadow-sm hover:border-blue-300 transition-colors group">
              <div class="flex items-center gap-3 overflow-hidden">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-red-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                </svg>
                <div class="overflow-hidden">
                  <p class="text-xs font-bold text-gray-900 truncate">
                    <%= @tender.pdf.attached? ? @tender.pdf.filename : "Sin archivo" %>
                  </p>
                  <p class="text-[10px] text-gray-400 uppercase">PDF • <%= @tender.pdf.attached? ? number_to_human_size(@tender.pdf.byte_size) : "0 KB" %></p>
                </div>
              </div>
              
              <% if @tender.pdf.attached? %>
                <%= link_to rails_blob_path(@tender.pdf, disposition: "attachment"), 
                            class: "p-2 bg-blue-50 text-blue-600 rounded-lg group-hover:bg-blue-600 group-hover:text-white transition-all",
                            title: "Descargar archivo",
                            download: true do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                  </svg>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%# COLUMNA DERECHA: ANÁLISIS DE IA %>
    <div class="lg:col-span-2">
      <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-md relative overflow-hidden min-h-[400px]">
        
        <%# BARRA DE PROGRESO ANIMADA (Oculta por defecto) %>
        <div id="ai-progress-container" class="hidden mb-10 p-6 bg-blue-50 rounded-2xl border border-blue-100 shadow-inner">
          <div class="flex justify-between items-end mb-3">
            <div>
              <span class="text-sm font-black text-blue-800 block mb-1 uppercase tracking-tighter">🤖 Procesando Documento...</span>
              <span class="text-xs text-blue-600 font-medium">IA analizando criterios de adjudicación</span>
            </div>
          </div>
          <div class="w-full bg-white rounded-full h-4 overflow-hidden shadow-inner p-1">
            <div class="bg-blue-600 h-full rounded-full animate-progress-stripes" style="width: 100%; background-image: linear-gradient(45deg,rgba(255,255,255,.2) 25%,transparent 25%,transparent 50%,rgba(255,255,255,.2) 50%,rgba(255,255,255,.2) 75%,transparent 75%,transparent); background-size: 1.5rem 1.5rem;"></div>
          </div>
          <p class="text-center text-[10px] text-blue-400 mt-3 italic animate-pulse">Este proceso lee el pliego completo. Tiempo estimado: 10-15 seg.</p>
        </div>

        <div id="ai-content-body" class="transition-opacity duration-500">
          <div class="flex items-center justify-between gap-4 mb-10">
            <h1 class="text-2xl font-black text-gray-900 tracking-tight">Informe de Viabilidad</h1>
            <span class="<%= badge_css %> px-5 py-2 rounded-full text-xs font-black border uppercase shadow-sm">
              <%= viabilidad.presence || "Pendiente de Análisis" %>
            </span>
          </div>

          <% if @tender.analysis_data.present? %>
            <div class="grid md:grid-cols-2 gap-10 mb-10">
              <div class="bg-blue-50/30 p-5 rounded-2xl border border-blue-50">
                <h3 class="text-[13px] font-black text-blue-600 uppercase tracking-[0.2em] mb-3">Objeto de la Licitación</h3>
                <p class="text-gray-700 leading-relaxed text-sm"><%= @tender.analysis_data['resumen_ejecutivo'] %></p>
              </div>
              <div class="bg-purple-50/30 p-5 rounded-2xl border border-purple-50">
                <h3 class="text-[13px] font-black text-blue-600 uppercase tracking-[0.2em] mb-3">Solvencia Requerida</h3>
                <p class="text-gray-700 leading-relaxed text-sm"><%= @tender.analysis_data['analisis_solvencia'] %></p>
              </div>
            </div>

            <div class="bg-gray-50 rounded-3xl p-8 border border-gray-100 shadow-inner">
              <h3 class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mb-5">Puntos Críticos Detectados</h3>
              <ul class="space-y-4">
                <% (@tender.analysis_data['puntos_clave'] || []).each do |punto| %>
                  <li class="flex items-start gap-4 group">
                    <div class="mt-1 bg-white p-1 rounded-md shadow-sm border border-gray-100 group-hover:border-blue-300 transition-colors">
                      <svg class="h-3 w-3 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                    <span class="text-gray-700 text-sm leading-relaxed font-medium"><%= punto %></span>
                  </li>
                <% end %>
              </ul>
            </div>
          <% else %>
            <div class="text-center py-24 bg-gray-50 rounded-3xl border-2 border-dashed border-gray-200">
              <div class="bg-white h-16 w-16 rounded-full flex items-center justify-center mx-auto shadow-sm mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <p class="text-gray-500 font-bold uppercase text-xs tracking-widest">Sin datos analizados</p>
              <p class="text-gray-400 text-xs mt-2 italic px-8 leading-relaxed text-balance">Ejecuta el motor de análisis para extraer los requisitos del PDF adjunto.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# 3. ACCIONES INFERIORES %>
  <div class="mt-12 bg-white p-6 rounded-2xl border border-gray-100 shadow-sm flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
    <div class="flex items-center gap-4">
      <div class="bg-gray-100 p-2.5 rounded-xl">
        <%= link_to tenders_path, class: "text-gray-600 hover:text-gray-900 transition-colors", title: "Volver al listado" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
        <% end %>
      </div>
      <div>
        <!-- <h4 class="text-sm font-bold text-gray-900">Navegación</h4> -->
        <p class="text-[15px] text-gray-500 uppercase tracking-tighter">Ver análisis anteriores</p>
        <!-- <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg> -->
      </div>
    </div>
    
    <%# BOTÓN DE ANÁLISIS %>
    <%= button_to analyze_tender_path(@tender), 
                  method: :post,
                  id: "analyze-button",
                  onclick: "document.getElementById('ai-progress-container').classList.remove('hidden'); document.getElementById('ai-content-body').style.opacity='0.2'; this.disabled=true; this.classList.add('opacity-50'); this.form.submit();",
                  class: "inline-flex items-center px-10 py-4 bg-blue-600 hover:bg-blue-700 text-white text-sm font-black rounded-2xl shadow-xl transition-all transform hover:scale-105 active:scale-95 group",
                  data: { turbo_confirm: "¿Confirmas el re-análisis con la IA?" } do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 group-hover:rotate-180 transition-transform duration-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
      </svg>
      <span>RE-ANALIZAR</span>
    <% end %>
  </div>
</div>

<style>
  @keyframes progress-stripes { from { background-position: 1.5rem 0; } to { background-position: 0 0; } }
  .animate-progress-stripes { animation: progress-stripes 1s linear infinite; }
</style>