<%# app/views/tenders/show.html.erb %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  
  <%# 1. Cabecera con el Título del Proyecto %>
  <div class="md:flex md:items-center md:justify-between border-b border-gray-200 pb-6 mb-8">
    <div class="flex-1 min-w-0">
      <h2 class="text-3xl font-bold leading-7 text-gray-900 sm:text-4xl sm:truncate">
        <%= @tender.title %>
      </h2>
    </div>
  </div>

  <%# 2. Diseño de dos columnas (Grid) %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
    
    <%# Columna IZQUIERDA: Datos Básicos %>
    <div class="lg:col-span-1 space-y-6">
      <div>
        <h4 class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Estado de Licitación</h4>
        <p class="mt-2 text-3xl font-bold text-gray-900">Activa</p>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Perfil de Empresa</h4>
        <p class="mt-1 text-gray-700 font-medium">
          <%= TenderEvaluator::COMPANY_PROFILE[:name] %>
        </p>
      </div>

      <div class="pt-6 border-t border-gray-100">
        <h4 class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Archivo PDF</h4>
        <div class="mt-3 flex items-center gap-3 p-3 bg-gray-50 rounded-xl border border-gray-100">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
          </svg>
          <div class="overflow-hidden">
            <p class="text-sm font-semibold text-gray-900 truncate">
              <%= @tender.pdf.attached? ? @tender.pdf.filename : "Sin archivo" %>
            </p>
            <p class="text-xs text-gray-500">
              <%= @tender.pdf.attached? ? number_to_human_size(@tender.pdf.byte_size) : "0 KB" %>
            </p>
          </div>
        </div>
      </div>
    </div>

    <%# Columna DERECHA: Análisis de IA %>
    <div class="lg:col-span-2">
      <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm relative overflow-hidden">
        
        <%# CAPA DE CARGA (Spinner) %>
        <div id="ai-loader" class="hidden absolute inset-0 bg-white/90 backdrop-blur-sm z-50 flex flex-col items-center justify-center">
          <svg class="animate-spin h-10 w-10 text-blue-600 mb-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <p class="text-lg font-bold text-blue-700 animate-pulse text-center px-6">
            Procesando pliego con GPT-4...<br>
            <span class="text-sm font-normal text-gray-500">Esto puede tardar hasta 15 segundos</span>
          </p>
        </div>

        <div class="flex items-center justify-between gap-4 mb-8">
          <h1 class="text-2xl font-bold text-gray-900 flex items-center gap-2">
            Informe de Viabilidad
          </h1>
          
          <% viabilidad = @tender.analysis_data&.[]('viabilidad') %>
          <span class="<%= case viabilidad; when 'Go' then 'bg-green-100 text-green-800 border-green-200'; when 'No-Go' then 'bg-red-100 text-red-800 border-red-200'; else 'bg-yellow-100 text-yellow-800 border-yellow-200'; end %> px-4 py-1.5 rounded-full text-sm font-bold border">
            <%= viabilidad.presence || "PENDIENTE" %>
          </span>
        </div>

        <% if @tender.analysis_data.present? %>
          <div class="grid md:grid-cols-2 gap-8 mb-8">
            <div>
              <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Resumen del Objeto</h3>
              <p class="text-gray-700 leading-relaxed"><%= @tender.analysis_data['resumen_ejecutivo'] %></p>
            </div>
            <div>
              <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Análisis de Solvencia</h3>
              <p class="text-gray-700 leading-relaxed"><%= @tender.analysis_data['analisis_solvencia'] %></p>
            </div>
          </div>

          <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
            <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Puntos Críticos Detectados</h3>
            <ul class="space-y-3 text-gray-700">
              <% @tender.analysis_data['puntos_clave'].each do |punto| %>
                <li class="flex items-start gap-3">
                  <svg class="h-5 w-5 text-blue-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span><%= punto %></span>
                </li>
              <% end %>
            </ul>
          </div>
        <% else %>
          <div class="text-center py-20 bg-gray-50 rounded-3xl border-2 border-dashed border-gray-200">
            <p class="text-gray-500 font-medium">Haz clic en el botón inferior para iniciar el análisis.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# 3. Panel de Acciones Inferior %>
  <div class="mt-12 bg-white p-6 rounded-2xl border border-gray-100 shadow-sm flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
    <div class="flex items-center gap-3">
      <div class="bg-blue-100 p-2 rounded-lg">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
      </div>
      <div>
        <h4 class="text-sm font-bold text-gray-900">Motor de Decisión</h4>
        <p class="text-xs text-gray-500">Impulsado por GPT-4o</p>
      </div>
    </div>
    
    <div class="flex items-center gap-3">
      <%= button_to analyze_tender_path(@tender), 
                    method: :post,
                    id: "analyze-button",
                    class: "inline-flex items-center px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold rounded-xl shadow-lg transition-all hover:scale-105 active:scale-95",
                    data: { turbo_confirm: "¿Quieres lanzar el análisis? Este proceso lee el pliego completo." } do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
        </svg>
        Re-analizar
      <% end %>

      <%= link_to tenders_path, class: "px-6 py-3 bg-gray-100 text-gray-700 text-sm font-bold rounded-xl hover:bg-gray-200 transition" do %>
        Atrás
      <% end %>

      <%= button_to "Eliminar", 
                    tender_path(@tender), 
                    method: :delete, 
                    class: "px-6 py-3 text-red-600 text-sm font-bold hover:bg-red-50 rounded-xl transition",
                    data: { turbo_confirm: "¿Borrar definitivamente?" } %>
    </div>
  </div>
</div>

<%# LÓGICA DE JAVASCRIPT PARA EL SPINNER %>
<script>
  document.addEventListener("turbo:load", () => {
    const analyzeButton = document.getElementById("analyze-button");
    const loader = document.getElementById("ai-loader");

    if (analyzeButton && loader) {
      analyzeButton.addEventListener("click", () => {
        // 1. Mostramos el spinner inmediatamente
        loader.classList.remove("hidden");
        
        // 2. Desactivamos el botón para evitar doble gasto en la API
        analyzeButton.disabled = true;
        analyzeButton.classList.add("opacity-50", "cursor-not-allowed");
        
        // 3. Opcional: Cambiar el texto del botón
        const buttonText = analyzeButton.querySelector('span') || analyzeButton;
        buttonText.innerText = "Analizando...";
      });
    }
  });
</script>