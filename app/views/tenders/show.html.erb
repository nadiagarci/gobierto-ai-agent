<%# app/views/tenders/show.html.erb %>

<% if @tender.analysis_data.present? %>
  <div class="mt-8 p-6 bg-white border border-gray-200 rounded-xl shadow-sm">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-gray-800">Análisis Inteligente (GPT-4)</h2>
      
      <%# Badge de Viabilidad con colores dinámicos %>
      <% viabilidad = @tender.analysis_data['viabilidad']&.downcase %>
      <span class="px-4 py-1 rounded-full text-sm font-semibold 
        <%= case viabilidad
            when 'go' then 'bg-green-100 text-green-700'
            when 'no-go' then 'bg-red-100 text-red-700'
            else 'bg-yellow-100 text-yellow-700'
            end %>">
        <%= @tender.analysis_data['viabilidad'] %>
      </span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <%# Resumen Ejecutivo %>
      <div class="space-y-2">
        <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider">Resumen Ejecutivo</h3>
        <p class="text-gray-700 leading-relaxed"><%= @tender.analysis_data['resumen_ejecutivo'] %></p>
      </div>

      <%# Solvencia %>
      <div class="space-y-2">
        <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider">Análisis de Solvencia</h3>
        <p class="text-gray-700 leading-relaxed"><%= @tender.analysis_data['analisis_solvencia'] %></p>
      </div>
    </div>

    <%# Puntos Clave %>
    <div class="mt-6 pt-6 border-t border-gray-100">
      <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-3">Requisitos Técnicos Clave</h3>
      <ul class="list-disc list-inside space-y-1 text-gray-700">
        <% @tender.analysis_data['puntos_clave']&.each do |punto| %>
          <li><%= punto %></li>
        <% end %>
      </ul>
    </div>
  </div>
<% else %>
  <div class="mt-8 p-6 bg-gray-50 border border-dashed border-gray-300 rounded-xl text-center">
    <p class="text-gray-500 italic">Análisis pendiente. Sube un PDF para procesar la licitación.</p>
  </div>
<% end %>