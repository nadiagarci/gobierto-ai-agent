<%# app/views/tenders/index.html.erb %>

<div class="fixed inset-0 bg-gray-50/50 -z-10"></div>

<div class="min-h-screen w-full py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <%# CABECERA %>
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10">
      <div>
        <h1 class="text-3xl font-black text-gray-900 tracking-tight">Historial de Análisis</h1>
        <p class="text-sm text-gray-500 mt-1 font-medium">Licitaciones ordenadas por fecha de análisis (más recientes primero).</p>
      </div>
      
      <%= link_to new_tender_path, class: "inline-flex items-center px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white text-xs font-black rounded-2xl shadow-lg shadow-blue-100 transition-all transform hover:scale-105 active:scale-95 uppercase tracking-widest gap-2" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4" />
        </svg>
        Nuevo Análisis
      <% end %>
    </div>

    <%# TABLA %>
    <div class="bg-white rounded-[2.5rem] border border-gray-100 shadow-[0_20px_50px_-12px_rgba(0,0,0,0.05)] overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b border-gray-50">
              <th class="px-8 py-5 text-[10px] font-black text-gray-400 uppercase tracking-[0.15em]">Proyecto / Estado</th>
              <th class="px-8 py-5 text-[10px] font-black text-gray-400 uppercase tracking-[0.15em]">Veredicto IA</th>
              <th class="px-8 py-5 text-[10px] font-black text-gray-400 uppercase tracking-[0.15em]">Fecha de Análisis</th>
              <th class="px-8 py-5 text-[10px] font-black text-gray-400 uppercase tracking-[0.15em] text-right">Gestión</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <%# .order(created_at: :desc) asegura que lo nuevo salga arriba %>
            <% @tenders.order(created_at: :desc).each do |tender| %>
              <% 
                viabilidad = tender.analysis_data&.[]('viabilidad')
                badge_css = case viabilidad
                            when 'Go' then 'bg-green-50 text-green-700 border-green-100'
                            when 'No-Go' then 'bg-red-50 text-red-700 border-red-100'
                            else 'bg-amber-50 text-amber-700 border-amber-100'
                            end
              %>
              <tr class="group hover:bg-gray-50/50 transition-colors">
                <td class="px-8 py-6">
                  <div class="flex items-center gap-4">
                    <%# Nuevo Avatar: Indicador de Actividad %>
                    <div class="h-10 w-10 bg-gray-50 rounded-xl flex items-center justify-center relative border border-gray-100 shadow-sm">
                      <span class="relative flex h-3 w-3">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span>
                      </span>
                    </div>
                    <div>
                      <p class="text-sm font-bold text-gray-900 group-hover:text-blue-600 transition-colors">
                        <%= tender.title.presence || "Licitación ##{tender.id}" %>
                      </p>
                      <div class="flex items-center gap-2 mt-0.5">
                        <span class="text-[9px] font-black text-green-600 uppercase tracking-tighter">Sigue Activa</span>
                        <span class="text-gray-300">•</span>
                        <p class="text-[10px] text-gray-400 uppercase font-medium tracking-tighter">
                          <%= tender.pdf.attached? ? tender.pdf.filename : "Sin PDF" %>
                        </p>
                      </div>
                    </div>
                  </div>
                </td>
                <td class="px-8 py-6">
                  <span class="<%= badge_css %> px-4 py-1.5 rounded-full text-[10px] font-black border uppercase tracking-widest shadow-sm inline-block">
                    <%= viabilidad.presence || "Pendiente" %>
                  </span>
                </td>
                <td class="px-8 py-6 text-sm text-gray-500 font-medium">
                  <%= tender.created_at.strftime("%d/%m/%Y") %>
                  <span class="text-[10px] text-gray-300 block font-normal"><%= tender.created_at.strftime("%H:%M") %>h</span>
                </td>
                <td class="px-8 py-6 text-right">
                  <div class="flex items-center justify-end gap-2">
                    <%# Ver Detalle %>
                    <%= link_to tender_path(tender), class: "inline-flex items-center justify-center h-10 w-10 bg-white border border-gray-100 text-gray-400 hover:text-blue-600 hover:border-blue-100 rounded-xl shadow-sm hover:shadow-md transition-all", title: "Ver informe" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    <% end %>

                    <%# Botón Eliminar %>
                    <%= button_to tender_path(tender), 
                        method: :delete, 
                        data: { confirm: "¿Estás seguro de que quieres eliminar este análisis?" }, 
                        class: "inline-flex items-center justify-center h-10 w-10 bg-white border border-gray-100 text-gray-400 hover:text-red-600 hover:border-red-100 rounded-xl shadow-sm hover:shadow-md transition-all",
                        title: "Eliminar" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                      </svg>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="w-full flex justify-center mt-auto py-12">
  <p class="text-[10px] text-gray-400 text-center max-w-sm italic leading-relaxed">
    Aviso: Este análisis es generado por modelos probabilísticos de IA. Los resultados deben ser validados por un experto legal antes de tomar decisiones de negocio.
  </p>
</div>
</div>