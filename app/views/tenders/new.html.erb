
<div class="fixed inset-0 mt-0 mb-0 bg-gray-50/50 -z-10"></div>

<%# Contenedor principal: centra todo el bloque en el medio del navegador %>
  <div class="min-h-screen w-full flex flex-col items-center justify-center bg-gray-50/50 px-4">
  <!-- <div class="min-h-screen w-full flex flex-col items-center justify-center bg-gray-50/50 px-4 pt-8 pb-12"> -->
  
  <%# 1. Branding / Hero %>
  <div class="text-center max-w-2xl mt-0 mb-12">
    <div class="inline-flex items-center px-4 py-2 rounded-full bg-blue-50 text-blue-700 text-xs font-bold uppercase tracking-widest mb-6 border border-blue-100">
      <span class="relative flex h-2 w-2 mr-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-amber-500"></span>
    </span>
       AI Engine Demo Mode • Public Beta
    </div>
    <h1 class="text-4xl sm:text-6xl font-black text-gray-900 tracking-tight mb-6">
      Analiza la viabilidad de tu <span class="text-blue-600">licitación</span>
    </h1>
    <p class="text-lg text-gray-500 leading-relaxed">
      Sube el pliego en PDF y nuestro agente inteligente evaluará la solvencia, puntos críticos y el veredicto Go/No-Go en segundos.
    </p>
  </div>

  <%# 2. Formulario Simple %>
  <div class="w-full max-w-md bg-white p-8 rounded-3xl border border-gray-100 shadow-2xl relative overflow-hidden">
    
    <%# BARRA DE CARGA (Oculta hasta el click) %>
    <div id="ai-progress-container" class="hidden absolute inset-0 z-50 bg-white/95 backdrop-blur-sm flex flex-col items-center justify-center p-8 text-center">
      <div class="w-full max-w-xs">
        <span class="text-sm font-black text-blue-700 block mb-4 uppercase">🤖 Procesando Documento...</span>
        <div class="w-full bg-gray-100 rounded-full h-3 overflow-hidden p-0.5 shadow-inner">
          <div class="bg-blue-600 h-full rounded-full animate-progress-stripes" style="width: 100%; background-image: linear-gradient(45deg,rgba(255,255,255,.2) 25%,transparent 25%,transparent 50%,rgba(255,255,255,.2) 50%,rgba(255,255,255,.2) 75%,transparent 75%,transparent); background-size: 1.5rem 1.5rem;"></div>
        </div>
        <p class="text-[11px] text-gray-400 mt-4 italic">Extrayendo cláusulas administrativas y requisitos técnicos...</p>
      </div>
    </div>

    <%= form_with(model: @tender, local: true, class: "space-y-6") do |f| %>
      <div>
        <%= f.label :title, "Nombre del Proyecto", class: "block text-xs font-bold text-gray-400 uppercase mb-2" %>
        <%= f.text_field :title, placeholder: "Ej: Desarrollo Web Ayuntamiento de Madrid", class: "w-full px-4 py-3 rounded-xl border-gray-200 focus:border-blue-500 focus:ring-blue-500 text-sm shadow-sm" %>
      </div>

      <div>
        <%= f.label :pdf, "Pliego (PDF)", class: "block text-xs font-bold text-gray-400 uppercase mb-2" %>
        <div class="relative group">
          <%= f.file_field :pdf, class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-bold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 cursor-pointer" %>
        </div>
      </div>

      <div class="pt-4">
        <%= f.submit "Analizar Licitación", 
                     onclick: "document.getElementById('ai-progress-container').classList.remove('hidden');",
                     class: "w-full py-4 bg-blue-600 hover:bg-blue-700 text-white font-black rounded-2xl shadow-lg transition-all transform hover:scale-[1.02] active:scale-95 flex items-center justify-center gap-2 cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <%# 3. Acceso al Historial %>
  <div class="mt-10">
    <%= link_to tenders_path, class: "flex items-center gap-2 text-gray-400 hover:text-blue-600 transition-colors font-bold text-sm" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
      </svg>
      Ver análisis anteriores
    <% end %>
  </div>

  <%# Texto legal al final de todo el bloque %>
  <p class="mt-12 text-[10px] text-gray-400 text-center max-w-sm italic leading-relaxed">
    Aviso: Este análisis es generado por modelos probabilísticos de IA. Los resultados deben ser validados por un experto legal antes de tomar decisiones de negocio.
  </p>
</div>

<style>
  @keyframes progress-stripes { from { background-position: 1.5rem 0; } to { background-position: 0 0; } }
  .animate-progress-stripes { animation: progress-stripes 1s linear infinite; }
</style>